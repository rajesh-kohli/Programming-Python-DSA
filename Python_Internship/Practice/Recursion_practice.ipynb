   "source": [
    "def foo(n,r):\n",
    "    if n == 0:\n",
    "        return 1\n",
    "    elif n%2 == 0:\n",
    "        return n + foo(n//2,r)\n",
    "    else:\n",
    "        return n - foo(n//3,r)\n",
    "\n",
    "foo(20,4)"
   ]
