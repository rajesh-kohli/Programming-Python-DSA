   "id": "a0001c25",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "2\n"
     ]
    }
   ],
   "source": [
    "def last_occ(arr: list[int], n:int, t:int) -> int:\n",
    "    for i in range(n-1, -1, -1):\n",
    "        if arr[i] == t:\n",
    "            return i\n",
    "    return -1\n",
    "\n",
    "n = int(input())\n",
    "t = int(input())\n",
    "\n",
    "arr = [int(input()) for _ in range(n)]\n",
    "\n",
    "print(last_occ(arr, n, t))"
   ]
  },
