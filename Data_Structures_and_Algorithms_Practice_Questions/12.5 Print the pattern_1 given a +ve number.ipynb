   "source": [
    "n = int(input())\n",
    "for i in range(1,n+1):\n",
    "    ## for the ith row print n-i spaces\n",
    "    for _ in range(n-i):\n",
    "        print(\" \", end = \" \")\n",
    "    \n",
    "    # followed by i stars starting with i in increasing order\n",
    "    for _ in range(i):\n",
    "        print(\"*\", end = \" \")\n",
    "    \n",
    "    print()"
   ]
