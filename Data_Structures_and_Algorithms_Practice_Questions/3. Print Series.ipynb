   "source": [
    "### Given two numbers say a and b, design an algorithm to print the following series [a+b, a+2*b, a+3*b] "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "ee6504d1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "10 12 4\n"
     ]
    }
   ],
   "source": [
    "a, b, n = map(int, input(\"Enter numbers a, b and n: \").split())\n",
    "print(a, b, n)\n",
    "lst = []"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "bc728c53",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[22, 34, 46, 58]\n"
     ]
    }
   ],
   "source": [
    "for i in range(1, n+1, 1):\n",
    "    num = a + b*i\n",
    "    lst.append(num)\n",
    "print(lst)"
   ]
  }
 ],
